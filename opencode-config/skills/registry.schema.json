{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencode.local/skills/registry.schema.json",
  "title": "OpenCode Skill Registry",
  "type": "object",
  "required": ["version", "skills", "profiles", "categories"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "lastUpdated": { "type": "string" },
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "category", "tags", "source", "dependencies", "synergies", "conflicts", "triggers"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "category": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source": {
            "type": "string",
            "enum": ["builtin", "superpowers", "custom"]
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "synergies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "conflicts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "triggers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "description": { "type": "string" },
                "required": { "type": "boolean" }
              },
              "required": ["name"],
              "additionalProperties": false
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "description": { "type": "string" },
                "required": { "type": "boolean" }
              },
              "required": ["name"],
              "additionalProperties": false
            }
          },
          "handoff": {
            "type": "object",
            "properties": {
              "receives_from": {
                "type": "array",
                "items": { "type": "string" }
              },
              "hands_off_to": {
                "type": "array",
                "items": { "type": "string" }
              },
              "context_preserved": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "version": { "type": "string" },
          "processPhase": {
            "type": "string",
            "enum": ["pre-analysis", "analysis", "implementation", "verification", "post-process"]
          },
          "domain": { "type": "string" },
          "selectionHints": {
            "type": "object",
            "properties": {
              "useWhen": {
                "type": "array",
                "items": { "type": "string" }
              },
              "avoidWhen": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "overlapCluster": {
            "type": "string",
            "description": "Name of the overlap cluster this skill belongs to (e.g. browser, debugging, orchestration)"
          },
          "canonicalEntrypoint": {
            "type": "boolean",
            "description": "Whether this skill is the preferred entry point for its overlap cluster"
          },
          "compositionRules": {
            "type": "object",
            "properties": {
              "canRunInParallel": { "type": "boolean" },
              "canChain": { "type": "boolean" },
              "executionPhase": {
                "type": "string",
                "enum": ["pre-analysis", "analysis", "implementation", "verification", "post-process"]
              },
              "maxRetries": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "skills", "triggers"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "skills": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "triggers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "version": { "type": "string" },
          "deprecated": { "type": "boolean" }
        }
      }
    },
    "categories": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "skills"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "skills": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
