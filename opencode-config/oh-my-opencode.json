{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": true,
  "agents": {
    "enabled": [
      "atlas",
      "hephaestus",
      "librarian",
      "metis",
      "momus",
      "oracle",
      "prometheus",
      "sisyphus",
      "explore"
    ],
"atlas": {
    "model": "nvidia/moonshotai/kimi-k2.5"
  },
  "hephaestus": {
    "model": "openai/gpt-5.3-codex"
  },
  "librarian": {
    "model": "google/gemini-2.5-flash"
  },
  "metis": {
    "model": "openai/gpt-5.2"
  },
  "momus": {
    "model": "nvidia/z-ai/glm-5"
  },
  "oracle": {
    "model": "openai/gpt-5.3-codex",
    "variant": "high"
  },
  "prometheus": {
    "model": "openai/gpt-5.3-codex"
  },
  "sisyphus": {
    "model": "openai/gpt-5.3-codex"
  },
  "explore": {
    "model": "google/gemini-2.5-flash"
  },
  "multimodal-looker": {
    "model": "google/gemini-2.5-flash"
  }
  },
  "mcp": {
    "context7": {
      "enabled": true
    },
    "distill": {
      "enabled": true
    },
    "playwright": {
      "enabled": true
    },
    "websearch": {
      "enabled": true
    }
  },
  "hooks": {
    "onStart": [
      "echo 'oh-my-opencode loaded with 9 agents and 4 MCP toggles + Antigravity account rotation'"
    ]
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.2",
      "routing": "scoring",
      "fallbacks": ["google/gemini-3.1-pro-preview", "google/gemini-3-flash-preview"]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "routing": "thompson-sampling",
      "fallbacks": ["google/gemini-3.1-pro-preview", "zen/zen/minimax-m2.5"]
    },
    "deep": {
      "model": "nvidia/z-ai/glm-5",
      "routing": "thompson-sampling",
      "fallbacks": ["openai/gpt-5.3-codex", "google/gemini-3.1-pro-preview"]
    },
    "artistry": {
      "model": "openai/gpt-5.2",
      "routing": "scoring",
      "fallbacks": ["google/gemini-3.1-pro-preview", "zen/zen/minimax-m2.5"]
    },
    "quick": {
      "model": "google/gemini-3-flash-preview",
      "routing": "scoring",
      "fallbacks": ["nvidia/moonshotai/kimi-k2.5", "zen/zen/glm-5"]
    },
    "unspecified-low": {
      "model": "nvidia/moonshotai/kimi-k2.5",
      "routing": "scoring",
      "fallbacks": ["google/gemini-3-flash-preview", "zen/zen/glm-5"]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "routing": "thompson-sampling",
      "fallbacks": ["google/gemini-3.1-pro-preview", "nvidia/z-ai/glm-5"]
    },
    "writing": {
      "model": "google/gemini-3-flash-preview",
      "routing": "scoring",
      "fallbacks": ["openai/gpt-5.2", "zen/zen/kimi-k2.5"]
    }
  }
}
