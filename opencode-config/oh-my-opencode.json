{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": true,
  "agents": {
    "enabled": [
      "atlas",
      "hephaestus",
      "librarian",
      "metis",
      "momus",
      "oracle",
      "prometheus",
      "sisyphus",
      "explore"
    ],
    "atlas": {
      "model": "nvidia/moonshotai/kimi-k2.5"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex"
    },
    "librarian": {
      "model": "google/gemini-3-flash-preview"
    },
    "metis": {
      "model": "openai/gpt-5.4"
    },
    "momus": {
      "model": "nvidia/z-ai/glm-5.1"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "prometheus": {
      "model": "nvidia/z-ai/glm-5.1"
    },
    "sisyphus": {
      "model": "openai/gpt-5.4"
    },
    "explore": {
      "model": "google/gemini-3-flash-preview"
    },
    "multimodal-looker": {
      "model": "google/gemini-3-flash-preview"
    }
  },
  "mcp": {
    "context7": {
      "enabled": true
    },
    "distill": {
      "enabled": true
    },
    "playwright": {
      "enabled": true
    },
    "websearch": {
      "enabled": true
    }
  },
  "hooks": {
    "onStart": [
      "echo 'oh-my-opencode loaded with 9 agents and 4 MCP toggles + Antigravity account rotation'"
    ]
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "routing": "scoring",
      "fallbacks": [
        "openai/gpt-5.4-mini",
        "google/gemini-3.1-pro-preview"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "routing": "thompson-sampling",
      "fallbacks": [
        "openai/gpt-5.4",
        "google/gemini-3.1-pro-preview"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "routing": "thompson-sampling",
      "fallbacks": [
        "openai/gpt-5.3-codex",
        "google/gemini-3.1-pro-preview"
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.4",
      "routing": "scoring",
      "fallbacks": [
        "openai/gpt-5.4-mini",
        "google/gemini-3.1-pro-preview"
      ]
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "routing": "scoring",
      "fallbacks": [
        "nvidia/moonshotai/kimi-k2.5",
        "google/gemini-3-flash-preview"
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "routing": "scoring",
      "fallbacks": [
        "nvidia/moonshotai/kimi-k2.5",
        "google/gemini-3-flash-preview"
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "routing": "thompson-sampling",
      "fallbacks": [
        "openai/gpt-5.3-codex",
        "nvidia/z-ai/glm-5.1"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.4-mini",
      "routing": "scoring",
      "fallbacks": [
        "deepseek-ai/deepseek-v3",
        "openai/gpt-5.3-codex"
      ]
    }
  }
}
