{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "agents": {
    "enabled": [
      "atlas",
      "hephaestus",
      "librarian",
      "metis",
      "momus",
      "oracle",
      "prometheus",
      "sisyphus"
    ],
    "atlas": {
      "model": "anthropic/claude-sonnet-4-5"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "librarian": {
      "model": "anthropic/claude-sonnet-4-5"
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "momus": {
      "model": "openai/gpt-5.2",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "variant": "high"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "multimodal-looker": {
      "model": "antigravity/antigravity-gemini-3-flash"
    }
  },
  "mcp": {
    "context7": {
      "enabled": true
    },
    "websearch": {
      "enabled": true
    }
  },
  "hooks": {
    "onStart": [
      "echo 'oh-my-opencode loaded with 8 agents and 2 MCP toggles + Antigravity account rotation'"
    ]
  },
  "categories": {
    "visual-engineering": {
      "model": "antigravity/antigravity-gemini-3-pro"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "artistry": {
      "model": "antigravity/antigravity-gemini-3-pro",
      "variant": "high"
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-5"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "writing": {
      "model": "antigravity/antigravity-gemini-3-flash"
    }
  }
}
