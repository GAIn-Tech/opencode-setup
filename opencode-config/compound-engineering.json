  "integration": {
    "plugin": {
      "name": "superpowers",
      "path": "~/.config/opencode/plugins/superpowers.js",
      "source": "https://github.com/obra/superpowers",
      "type": "skill-framework"
    },
    "skills_directory": "~/.config/opencode/skills/",
    "commands_directory": "~/.config/opencode/commands/",
    "slash_commands": true,
    "task_loadable": true
  },
  "usage": {
    "slash_command": "/<command-name>",
    "task_loading": "load_skills=['skill-name']",
    "example": {
      "slash": "/plan 'Implement feature X'",
      "task": "task(category='unspecified-high', load_skills=['writing-plans'], prompt='Create plan for feature X')"
    }
  }
