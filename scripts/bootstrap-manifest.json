{
  "schemaVersion": 1,
  "policy": {
    "scope": "entire-declared-surface",
    "officialSource": "authoritative-static-manifest",
    "notes": [
      "Official plugins are explicitly listed here and must not be inferred from uncontrolled runtime state.",
      "Validator extends official checks to every declared plugin directory under plugins/ and cross-references plugin specs against opencode-config/opencode.json."
    ]
  },
  "ownershipDefaults": {
    "owner": "platform-bootstrap",
    "contact": "#opencode-bootstrap",
    "failureAction": "block-bootstrap"
  },
  "core": [
    {
      "id": "setup-resilient",
      "description": "Primary one-command bootstrap entry point",
      "ownership": {
        "owner": "platform-bootstrap",
        "contact": "#opencode-bootstrap",
        "failureAction": "block-bootstrap"
      },
      "loadChecks": {
        "requiredFiles": [
          "scripts/setup-resilient.mjs"
        ],
        "entryPoints": [
          "scripts/setup-resilient.mjs"
        ]
      }
    },
    {
      "id": "verify-setup",
      "description": "Setup readiness and integrity verification",
      "ownership": {
        "owner": "platform-bootstrap",
        "contact": "#opencode-bootstrap",
        "failureAction": "block-bootstrap"
      },
      "loadChecks": {
        "requiredFiles": [
          "scripts/verify-setup.mjs"
        ],
        "entryPoints": [
          "scripts/verify-setup.mjs"
        ]
      }
    },
    {
      "id": "sync-user-config",
      "description": "Post-pull reconcile command for deterministic config sync",
      "ownership": {
        "owner": "platform-bootstrap",
        "contact": "#opencode-bootstrap",
        "failureAction": "warn-and-block-ci"
      },
      "loadChecks": {
        "requiredFiles": [
          "scripts/sync-user-config.mjs"
        ],
        "entryPoints": [
          "scripts/sync-user-config.mjs"
        ]
      }
    },
    {
      "id": "canonical-opencode-config",
      "description": "Canonical plugin/model/MCP configuration",
      "ownership": {
        "owner": "config-governance",
        "contact": "#opencode-config",
        "failureAction": "block-bootstrap"
      },
      "loadChecks": {
        "requiredFiles": [
          "opencode-config/opencode.json"
        ],
        "entryPoints": [
          "opencode-config/opencode.json"
        ]
      }
    },
    {
      "id": "plugin-metadata-catalog",
      "description": "Canonical external plugin metadata index",
      "ownership": {
        "owner": "plugin-governance",
        "contact": "#opencode-plugins",
        "failureAction": "warn-and-block-ci"
      },
      "loadChecks": {
        "requiredFiles": [
          "plugins/README.md"
        ],
        "entryPoints": [
          "plugins/README.md"
        ]
      }
    }
  ],
  "officialPlugins": [
    {
      "id": "oh-my-opencode",
      "package": "oh-my-opencode@3.5.2",
      "ownership": {
        "owner": "agent-platform",
        "contact": "#opencode-agents",
        "failureAction": "block-bootstrap"
      },
      "loadChecks": {
        "requiredFiles": [
          "plugins/oh-my-opencode/info.md"
        ],
        "entryPoints": [
          "plugins/oh-my-opencode/info.md"
        ],
        "opencodePluginSpec": "oh-my-opencode@3.5.2"
      }
    },
