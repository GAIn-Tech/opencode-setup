{
  "opencode_root": "{{OPENCODE_ROOT}}",
  "mcp_servers": [
    {
      "name": "supermemory",
      "enabled": true,
      "type": "remote"
    },
    {
      "name": "context7",
      "enabled": true,
      "type": "remote"
    },
    {
      "name": "playwright",
      "command": [
        "bunx",
        "@playwright/mcp@0.0.64"
      ],
      "enabled": true,
      "type": "local"
    },
    {
      "name": "sequentialthinking",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "type": "local"
    },
    {
      "name": "websearch",
      "command": [
        "bunx",
        "-y",
        "@ignidor/web-search-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    {
      "name": "grep",
      "command": [
        "uvx",
        "grep-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    {
      "name": "distill",
      "command": [
        "bun",
        "scripts/run-distill-mcp.mjs",
        "serve",
        "--lazy"
      ],
      "enabled": true,
      "type": "local"
    },
    {
      "name": "opencode-dashboard-launcher",
      "command": [
        "bun",
        "packages/opencode-dashboard-launcher/src/index.js"
      ],
      "enabled": false,
      "type": "local"
    },
    {
      "name": "opencode-memory-graph",
      "command": [
        "bun",
        "packages/opencode-memory-graph/src/mcp-server.mjs"
      ],
      "enabled": true,
      "type": "local"
    },
    {
      "name": "opencode-context-governor",
      "command": [
        "bun",
        "packages/opencode-context-governor/src/mcp-server.mjs"
      ],
      "enabled": true,
      "type": "local"
    },
    {
      "name": "opencode-runbooks",
      "command": [
        "bun",
        "packages/opencode-runbooks/src/mcp-server.mjs"
      ],
      "enabled": true,
      "type": "local"
    }
  ]
}
