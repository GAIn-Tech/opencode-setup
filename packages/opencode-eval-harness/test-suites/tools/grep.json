/**
 * Test suite for grep MCP tool
 * Tests: code search, pattern matching
 */
[
  {
    "id": "grep-search-typescript",
    "prompt": "Search for 'function' in TypeScript files under src/",
    "expected_result_shape": {
      "type": "text",
      "value": "function",
      "match": "contains"
    },
    "complexity_tier": 1,
    "category": "search",
    "max_tokens": 2048
  },
  {
    "id": "grep-search-react-hooks",
    "prompt": "Search for 'useState' hook usage in React component files",
