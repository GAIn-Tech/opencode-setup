      "type": "text",
      "value": "useState",
      "match": "contains"
    },
    "complexity_tier": 1,
    "category": "search",
    "max_tokens": 2048
  },
  {
    "id": "grep-regex-pattern",
    "prompt": "Search using regex pattern 'console\\\\.log\\\\(.*\\\\)' to find all console.log statements",
    "expected_result_shape": {
      "type": "text",
      "value": "console",
      "match": "contains"
    },
    "complexity_tier": 2,
    "category": "regex-search",
    "max_tokens": 2048
  },
  {
    "id": "grep-language-filter",
    "prompt": "Search for 'class' in Python files only",
    "expected_result_shape": {
      "type": "text",
      "value": "class",
      "match": "contains"
    },
    "complexity_tier": 1,
    "category": "language-filter",
    "max_tokens": 1024
  },
  {
    "id": "grep-case-sensitive",
    "prompt": "Case-sensitive search for 'CONSTANT' in the codebase",
    "expected_result_shape": {
      "type": "text",
      "value": "CONSTANT",
      "match": "contains"
    },
    "complexity_tier": 1,
    "category": "search-options",
    "max_tokens": 1024
  },
  {
    "id": "grep-no-results",
    "prompt": "Search for 'definitelynon_existent123' and verify empty results handled",
    "expected_result_shape": {
      "type": "text",
      "value": "found",
      "match": "any_present"
    },
    "complexity_tier": 1,
    "category": "error-handling",
    "max_tokens": 256
  },
  {
    "id": "grep-repo-filter",
    "prompt": "Search for 'async function' in facebook/react repository",
