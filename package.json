{
  "name": "opencode-setup",
  "version": "1.0.0",
  "description": "OpenCode custom plugins and configuration",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup-resilient.mjs",
    "setup:base": "node scripts/preflight-versions.mjs && bun install && bun run link-all && bun run hooks:install && bun run copy-config && bun run generate",
    "copy-config": "node scripts/copy-config.mjs",
    "link-all": "node scripts/link-packages.mjs",
    "install-to-opencode": "bun install && bun run link-all",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "generate": "node scripts/generate-mcp-config.mjs",
    "verify": "node scripts/verify-setup.mjs",
    "verify:strict": "node scripts/copy-config.mjs && node scripts/generate-mcp-config.mjs && node scripts/verify-setup.mjs && node scripts/validate-plugin-compatibility.mjs && node scripts/verify-portability.mjs --strict",
    "protocol:compliance": "node scripts/protocol-compliance-pass.mjs",
    "runtime:compliance": "node scripts/runtime-context-compliance.mjs",
    "runtime:workflow-scenarios": "node scripts/runtime-workflow-scenarios.mjs",
    "fix:bun-path": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { .\\scripts\\fix-bun-path.ps1 -PersistUser; node .\\scripts\\verify-setup.mjs }\"",
    "health": "node scripts/health-check.mjs",
    "health:system": "node scripts/system-health.mjs",
    "health:system:verbose": "node scripts/system-health.mjs --verbose",
    "integrity:check": "node scripts/integrity-guard.mjs",
    "config:migrate": "node scripts/migrate-central-config.mjs",
    "config:coherence": "node scripts/validate-config-coherence.mjs",
    "models:validate": "node scripts/validate-models.mjs",
    "ci:boundary": "node scripts/ci-boundary-enforce.mjs",
    "policies:validate": "node scripts/validate-policies-structure.mjs",
    "models:sync": "node scripts/weekly-model-sync.mjs",
    "opencode:with-dashboard": "node scripts/opencode-with-dashboard.mjs",
    "test:skillrl-api": "bun test integration-tests/skillrl-api-regression.test.js",
    "smoke": "node scripts/smoke-pipeline.mjs",
    "mcp:smoke": "node scripts/mcp-smoke-harness.mjs",
    "mcp:exercise": "node scripts/mcp-exercise-harness.mjs",
    "mcp:runtime-proof": "node scripts/runtime-tool-surface-proof.mjs",
    "packages:smoke": "node scripts/run-package-smokes.mjs",
    "gate:learning": "node scripts/learning-gate.mjs --staged",
    "state:deploy": "node scripts/deployment-state.mjs",
    "warning:check": "bun scripts/ci-warning-budget.mjs --check",
    "warning:capture": "bun scripts/ci-warning-budget.mjs --capture",
    "governance:check": "node scripts/learning-gate.mjs --staged && node scripts/deployment-state.mjs check-flow && node scripts/integrity-guard.mjs && bun run warning:check",
    "mcp:report": "node scripts/report-mcp-lifecycle.mjs",
    "q": "node scripts/rebuild-q-runtime.mjs",
    "q:recover": "node scripts/rebuild-q-runtime.mjs",
    "skills": "node scripts/skills-manage.mjs list --all",
    "skills:list": "node scripts/skills-manage.mjs list",
    "skills:add": "node scripts/skills-manage.mjs add",
    "skills:enable": "node scripts/skills-manage.mjs enable",
    "skills:disable": "node scripts/skills-manage.mjs disable",
    "skills:audit": "node scripts/skills-manage.mjs audit",
    "skills:sync": "node scripts/skills-manage.mjs sync",
    "meta-kb:synthesize": "node scripts/synthesize-meta-kb.mjs",
    "meta-kb:drift": "node scripts/check-agents-drift.mjs",
    "meta-kb:check": "node scripts/synthesize-meta-kb.mjs && node scripts/check-agents-drift.mjs",
    "codebase:analyze": "bun packages/opencode-codebase-memory/src/cli.mjs analyze . --name opencode-setup"
  },
  "main": "index.js",
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GAIn-Tech/opencode-setup.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/GAIn-Tech/opencode-setup/issues"
  },
  "homepage": "https://github.com/GAIn-Tech/opencode-setup#readme",
  "dependencies": {
    "sqlite-vec": "^0.1.7-alpha.2"
  }
}
