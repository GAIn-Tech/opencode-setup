{
  "name": "opencode-cli-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Insulated Bun workspace for OpenCode CLI v2 migration",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,js,md,toml,yml,yaml}\""
  },
  "dependencies": {
    "oh-my-opencode": "file:../local/oh-my-opencode",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
